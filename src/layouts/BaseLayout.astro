---
import '../styles/globals.css';
import Header from '../components/nav/Header.astro';
import Footer from '../components/layout/Footer.astro';
import SEO from '../components/seo/SEO.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  transparentHeader?: boolean;
  heroPreload?: {
    imagesrcset: string;
    imagesizes: string;
  };
  canonical?: string;
  noindex?: boolean;
}
const {
  title,
  description,
  ogImage,
  transparentHeader = false,
  heroPreload,
  canonical,
  noindex,
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO title={title} description={description} ogImage={ogImage} canonical={canonical} noindex={noindex} />
    {heroPreload && (
      <link
        rel="preload"
        as="image"
        imagesrcset={heroPreload.imagesrcset}
        imagesizes={heroPreload.imagesizes}
        fetchpriority="high"
      />
    )}
    <slot name="head" />
  </head>
  <body class="flex min-h-svh flex-col">
    <a href="#main" class="sr-only-focusable">Skip to content</a>
    <Header transparent={transparentHeader} />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
