---
import { ASPECT, buildImageUrl, buildSrcset, IMG_SIZES, type ImageSource } from '../../lib/images';

interface Props {
  src: string;
  alt: string;
  source?: ImageSource;
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  minHeight?: string;
  overlay?: 'soft' | 'strong' | 'none';
}
const {
  src,
  alt,
  source = 'picsum',
  eyebrow,
  title,
  subtitle,
  align = 'left',
  minHeight = 'min-h-[70svh] lg:min-h-[82svh]',
  overlay = 'soft',
} = Astro.props;

const srcset = buildSrcset(src, source, 'hero', ASPECT.hero);
const sizes = IMG_SIZES.hero;
const fallback = buildImageUrl(src, source, 1600, 900);

const overlayClass = {
  soft: 'bg-gradient-to-t from-forest-900/70 via-forest-900/30 to-transparent',
  strong: 'bg-gradient-to-t from-forest-900/85 via-forest-900/50 to-forest-900/20',
  none: '',
}[overlay];
---
<section class:list={['relative w-full overflow-hidden', minHeight]}>
  <img
    src={fallback}
    srcset={srcset}
    sizes={sizes}
    alt={alt}
    width="1600"
    height="900"
    loading="eager"
    decoding="async"
    fetchpriority="high"
    class="absolute inset-0 h-full w-full object-cover"
  />
  {overlay !== 'none' && <div class:list={['absolute inset-0', overlayClass]} aria-hidden="true"></div>}
  <div class:list={[
    'relative z-10 mx-auto max-w-container h-full flex flex-col justify-end px-5 sm:px-8 lg:px-12 pb-12 lg:pb-20',
    align === 'center' ? 'items-center text-center' : 'items-start',
  ]}>
    {eyebrow && <p class="text-xs uppercase tracking-[0.24em] text-gold-400 mb-4">{eyebrow}</p>}
    <h1 class:list={['text-display-xl font-display text-sand-50 max-w-4xl', align === 'center' ? 'mx-auto' : '']}>{title}</h1>
    {subtitle && (
      <p class:list={['mt-5 max-w-prose-wide text-lg text-sand-50/90', align === 'center' ? 'mx-auto' : '']}>{subtitle}</p>
    )}
    <slot />
  </div>
</section>
