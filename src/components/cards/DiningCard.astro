---
import SmartImage from '../media/SmartImage.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  property: CollectionEntry<'properties'>;
}
const { property } = Astro.props;
const { name, cuisine, tagline, hours, cardImage, location } = property.data;
const href = `/dining/${property.slug}`;
---
<article class="group overflow-hidden rounded-2xl bg-cream border border-forest-900/10 hover:border-forest-900/20 transition-colors duration-300">
  <a href={href} class="block" aria-label={`Discover ${name}`}>
    <SmartImage
      src={cardImage.src}
      alt={cardImage.alt}
      source={cardImage.source}
      variant="card"
      aspect="card"
      rounded={false}
    />
  </a>
  <div class="p-5">
    <p class="text-xs uppercase tracking-widest text-gold-500 mb-1">{cuisine}</p>
    <h3 class="text-2xl font-display text-forest-900 mb-1">
      <a href={href} class="hover:text-clay-600 transition-colors">{name}</a>
    </h3>
    <p class="text-sm text-forest-700/90 italic mb-3">{tagline}</p>
    <div class="flex items-center justify-between text-xs text-forest-700/70">
      <span>{location.city}</span>
      {hours && <span class="text-right">{hours.split('·')[0].trim()}</span>}
    </div>
  </div>
</article>
