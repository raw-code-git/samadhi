---
import SmartImage from '../media/SmartImage.astro';
import Chip from '../ui/Chip.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  property: CollectionEntry<'properties'>;
  layout?: 'tall' | 'wide';
}
const { property, layout = 'tall' } = Astro.props;
const { name, type, tagline, shortDescription, location, cardImage, cuisine } = property.data;
const href = type === 'resort' ? `/stays/${property.slug}` : `/dining/${property.slug}`;
const eyebrow = type === 'resort'
  ? `${location.city} · ${location.country}`
  : cuisine ?? location.city;
---
<article class:list={[
  'group overflow-hidden rounded-2xl bg-sand-50 shadow-card hover:shadow-cardHover transition-shadow duration-300',
  layout === 'wide' ? 'lg:grid lg:grid-cols-2' : '',
]}>
  <a href={href} class="block relative" aria-label={`Discover ${name}`}>
    <SmartImage
      src={cardImage.src}
      alt={cardImage.alt}
      source={cardImage.source}
      variant="card"
      aspect={layout === 'wide' ? 'card' : 'card'}
      class="rounded-none"
      rounded={false}
    />
  </a>
  <div class="p-6 lg:p-8 flex flex-col gap-3">
    <div class="flex items-center gap-2">
      <Chip tone="gold">{type === 'resort' ? 'Stay' : 'Dining'}</Chip>
      <span class="text-xs uppercase tracking-wider text-forest-700/70">{eyebrow}</span>
    </div>
    <h3 class="text-display-md font-display text-forest-900">
      <a href={href} class="hover:text-clay-600 transition-colors">{name}</a>
    </h3>
    <p class="text-sm text-forest-700/90 italic">{tagline}</p>
    <p class="text-sm text-ink/80 leading-relaxed">{shortDescription}</p>
    <div class="mt-3 flex items-center gap-2 text-clay-600 text-sm font-medium">
      <a href={href} class="inline-flex items-center gap-1 group-hover:gap-2 transition-[gap]">
        {type === 'resort' ? 'Explore the resort' : 'Read more'}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</article>
