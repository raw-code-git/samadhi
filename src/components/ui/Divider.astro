---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---
<div class:list={['flex items-center gap-4 my-6', className]} aria-hidden="true">
  <span class="h-px flex-1 bg-forest-900/15"></span>
  <svg width="18" height="18" viewBox="0 0 18 18" class="text-gold-500" fill="currentColor">
    <circle cx="9" cy="9" r="2" />
    <circle cx="2" cy="9" r="1" opacity="0.6" />
    <circle cx="16" cy="9" r="1" opacity="0.6" />
  </svg>
  <span class="h-px flex-1 bg-forest-900/15"></span>
</div>
