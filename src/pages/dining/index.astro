---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/layout/Container.astro';
import Section from '../../components/layout/Section.astro';
import DiningCard from '../../components/cards/DiningCard.astro';
import JsonLd from '../../components/seo/JsonLd.astro';
import { breadcrumbLD } from '../../lib/jsonld';

const properties = await getCollection('properties');
const dining = properties
  .filter((p) => p.data.type === 'dining')
  .sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout
  title="Dining"
  description="Five restaurants and bars across Kuala Lumpur and Tioman Island: Tamarind Hill, Tamarind Springs, FOOK, Than, and Barra."
>
  <Fragment slot="head">
    <JsonLd data={breadcrumbLD([{ name: 'Home', href: '/' }, { name: 'Dining', href: '/dining' }])} />
  </Fragment>
  <Section tone="cream">
    <Container>
      <div class="max-w-prose-wide">
        <p class="text-xs uppercase tracking-[0.24em] text-clay-600 mb-3">Dining</p>
        <h1 class="text-display-xl font-display">Five kitchens, five points of view.</h1>
        <p class="mt-5 text-lg text-forest-700">Northern Thai in a pre-war bungalow. Cambodian cooking by a rainforest stream. Dim sum, a cliffside kitchen, pizza on the sand. Each restaurant was built for a single idea and stayed there.</p>
      </div>
    </Container>
  </Section>

  <Section tone="cream">
    <Container>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {dining.map((d) => <DiningCard property={d} />)}
      </div>
    </Container>
  </Section>
</BaseLayout>
