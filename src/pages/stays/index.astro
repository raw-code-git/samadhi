---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/layout/Container.astro';
import Section from '../../components/layout/Section.astro';
import PropertyCard from '../../components/cards/PropertyCard.astro';
import JsonLd from '../../components/seo/JsonLd.astro';
import { breadcrumbLD } from '../../lib/jsonld';

const properties = await getCollection('properties');
const stays = properties
  .filter((p) => p.data.type === 'resort')
  .sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout
  title="Stays"
  description="Two boutique resorts across Malaysia: Villa Samadhi in Kuala Lumpur and Japamala on Tioman Island."
>
  <Fragment slot="head">
    <JsonLd data={breadcrumbLD([{ name: 'Home', href: '/' }, { name: 'Stays', href: '/stays' }])} />
  </Fragment>
  <Section tone="cream">
    <Container>
      <div class="max-w-prose-wide">
        <p class="text-xs uppercase tracking-[0.24em] text-clay-600 mb-3">Stays</p>
        <h1 class="text-display-xl font-display">Two places. Two quiet silences.</h1>
        <p class="mt-5 text-lg text-forest-700">A walled garden in the middle of Kuala Lumpur, or an eleven-acre island on the edge of the South China Sea. Pick your quiet.</p>
      </div>
    </Container>
  </Section>

  <Section tone="cream">
    <Container>
      <div class="grid gap-10 lg:gap-14">
        {stays.map((p, i) => <PropertyCard property={p} layout={i % 2 === 0 ? 'wide' : 'wide'} />)}
      </div>
    </Container>
  </Section>
</BaseLayout>
