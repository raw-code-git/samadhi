---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/layout/Container.astro';
import Section from '../components/layout/Section.astro';
import Button from '../components/ui/Button.astro';
---
<BaseLayout title="Not found" noindex>
  <Section tone="cream">
    <Container narrow>
      <div class="text-center py-10">
        <p class="text-xs uppercase tracking-[0.24em] text-clay-600 mb-3">404</p>
        <h1 class="text-display-xl font-display">This path is overgrown.</h1>
        <p class="mt-5 text-forest-700 max-w-prose-wide mx-auto">The page you were looking for has moved or never existed. Try one of the routes below.</p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <Button href="/" variant="primary">Home</Button>
          <Button href="/stays" variant="outline">Stays</Button>
          <Button href="/dining" variant="outline">Dining</Button>
          <Button href="/gallery" variant="outline">Gallery</Button>
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>
